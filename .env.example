# Set to "false" once the FastAPI backend is live
VITE_USE_MOCKS=true

# Base URL for the future FastAPI service
VITE_API_BASE_URL=http://localhost:8000/api

# WebSocket URL for the future real-time translation stream
VITE_WS_URL=ws://localhost:8000/ws/translate

# Speech recognition now has a real implementation (Web Speech API), used
# by default. Set to "true" to fall back to the scripted demo words -
# useful on a browser without mic access, or without Web Speech support
# (Firefox, Safari).
VITE_USE_MOCK_SPEECH=false

# Hand detection now has a real implementation (MediaPipe HandLandmarker),
# used by default. Set to "true" to fall back to the old mocked timer -
# useful on a machine without a working webcam.
VITE_USE_MOCK_CAMERA=false
